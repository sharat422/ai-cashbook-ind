# ---------------------------------------------------------------------------
# Smart CashBook — FastAPI backend environment
# Copy to `.env` (same folder) and adjust. `.env` is git-ignored.
# ---------------------------------------------------------------------------

# Database. SQLite (zero-setup, default) or PostgreSQL.
#   SQLite:     sqlite:///./cashbook.db
#   PostgreSQL: postgresql+psycopg2://user:pass@localhost:5432/cashbook
DATABASE_URL=sqlite:///./cashbook.db

# JWT signing secret — CHANGE THIS in any real deployment.
JWT_SECRET=dev-secret-change-me
JWT_EXPIRE_MINUTES=43200

# Public URL the mobile app can reach this server at. Used to build absolute
# attachment URLs. Match what the app's API_BASE_URL points to.
#   Android emulator -> http://10.0.2.2:8000
#   iOS simulator    -> http://localhost:8000
PUBLIC_BASE_URL=http://10.0.2.2:8000

# Dev conveniences. With DEBUG=true the OTP is printed to the server log and the
# MASTER_OTP is always accepted (so you can log in without an SMS provider).
DEBUG=true
MASTER_OTP=123456

# --- AI providers (server-side only; never shipped to the mobile client) ---
# OpenAI GPT powers expense categorization (/categorize) and khata insights
# (/khata/insights). Leave blank to use the built-in heuristic fallback.
OPENAI_API_KEY=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
OPENAI_MODEL=gpt-4o-mini

# Anthropic Claude powers receipt OCR/extraction (/receipts/scan). Leave blank
# to return an empty draft the user fills in manually.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# CORS. "*" is fine for local development.
CORS_ORIGINS=*
