# ---------------------------------------------------------------------------
# Smart CashBook — environment variables (react-native-config)
#
# Copy this file to `.env` and adjust per environment. `.env` is git-ignored.
# After changing values you MUST rebuild the native app (env is inlined at
# build time, not read at runtime): `npm run android` / `npm run ios`.
# ---------------------------------------------------------------------------

# Base URL of the FastAPI backend (no trailing slash, no /api).
# Production / TestFlight builds MUST use the public HTTPS backend below so a
# real device can reach it (and iOS ATS allows the HTTPS request).
#   Public (Render)   -> https://smart-cashbook-api.onrender.com
# For purely local dev, swap to one of these and rebuild:
#   Android emulator  -> http://10.0.2.2:8000   (10.0.2.2 = host loopback)
#   iOS simulator     -> http://localhost:8000
#   Physical device   -> http://<your-LAN-ip>:8000
API_BASE_URL=https://smart-cashbook-api.onrender.com

# API version path segment. Requests go to {API_BASE_URL}/api/{API_VERSION}/...
API_VERSION=v1

# Network request timeout in milliseconds.
API_TIMEOUT_MS=15000

# Page size for paginated lists (transaction history infinite scroll).
# Keep modest (10–30) so each page renders fast on low-end devices.
TRANSACTIONS_PAGE_SIZE=20

# Timeout (ms) for the AI receipt scan request. OCR + AI extraction on the
# backend is slower than a normal request, so give it more headroom.
RECEIPT_SCAN_TIMEOUT_MS=45000

# Confidence (0..1) below which the categorization result is flagged for review.
CATEGORIZATION_CONFIDENCE_THRESHOLD=0.6

# Default hour (0-23, local time) the daily summary notification fires.
DAILY_SUMMARY_DEFAULT_HOUR=20

# Enable the WhatsApp delivery channel for the daily summary. Leave false until
# the backend WhatsApp integration is configured (see docs/DAILY_SUMMARY_MODULE.md).
WHATSAPP_ENABLED=false
